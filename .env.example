# ─────────────────────────────────────────────
# Hylunian Backend — Environment Configuration
# ─────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database (relative to project root)
DB_PATH=./data/hylunian.db

# JWT Authentication
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-chars
JWT_EXPIRES_IN=24h

# Admin Registration Invite Code
ADMIN_INVITE_CODE=hylunian-alpha-2026

# SMTP Email Configuration
# For development: use https://ethereal.email/ for test credentials
# For production: use SendGrid, AWS SES, Postmark, or Gmail App Password
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@hylunian.com
APP_NAME=Hylunian
